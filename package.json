{
  "name": "vetbuddy-overlay",
  "version": "1.1.0",
  "description": "VetBuddy Desktop Overlay - real-time consultation assistant",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:all": "npm run build && electron-builder --mac --win"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "axios": "^1.7.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.7.0",
    "react-audio-visualize": "^1.2.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "ai.vetbuddy.overlay",
    "productName": "VetBuddy Overlay",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "generic",
      "url": "https://vetbuddy-385b2.web.app/updates"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.medical",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
